<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >
    <data>
        <variable
            name="split"
            type="com.example.expensetrackerapplication.viewmodel.SplitViewModel" />
    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        >
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardElevation="5dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/idHeading"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:text="@string/split_payment_type"
                    android:textSize="@dimen/sub_header_size"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:background="?attr/colorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/idTotAmtLayout"
                    />

                <LinearLayout
                    android:id="@+id/idTotAmtLayout"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/idHeading"
                    app:layout_constraintBottom_toTopOf="@id/idLAmtInCash"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    <TextView
                        android:id="@+id/idTotAmtValue"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@{split.totAmtUi}"
                        android:textSize="@dimen/sub_header_size"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="?attr/colorPrimary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/idLAmtInCash"
                        />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/idLAmtInCash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    app:layout_constraintTop_toBottomOf="@id/idTotAmtLayout"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/idLAmtInCard"
                    >
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/idEAmtInCash"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:drawableStart="@drawable/cash"
                        android:drawablePadding="10dp"
                        android:text="@={split._amtInCash}"
                        android:textSize="@dimen/text_size"
                        android:hint="@string/enter_cash_amount"/>

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/idLAmtInCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    app:layout_constraintTop_toBottomOf="@id/idLAmtInCash"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/idLAmtInUpi"
                    >
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/idEAmtInCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:drawableStart="@drawable/card"
                        android:drawablePadding="10dp"
                        android:text="@={split._amtInCard}"
                        android:textSize="@dimen/text_size"
                        android:hint="@string/enter_card_amount"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/idLAmtInUpi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    app:layout_constraintTop_toBottomOf="@id/idLAmtInCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/idLayout"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/idEAmtInUpi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/upi"
                        android:drawablePadding="10dp"
                        android:text="@={split._amtInUpi}"
                        android:hint="@string/enter_upi_amount"
                        android:inputType="numberDecimal"
                        android:nextFocusDown="@id/idBtnOk"
                        android:textSize="@dimen/text_size"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>


                <LinearLayout
                    android:id="@+id/idLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_margin="10dp"
                    app:layout_constraintTop_toBottomOf="@id/idLAmtInUpi"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/idBtnCancel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:text="@string/cancel"
                        android:onClick="@{()->split.onClickCancel()}"
                        android:textColor="?attr/colorPrimary"
                        android:textColorLink="?attr/colorPrimary"
                        android:textSize="@dimen/button_text_size"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/idBtnOk"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:textColor="?attr/colorPrimary"
                        android:background="?attr/selectableItemBackground"
                        android:text= "@string/ok"
                        android:textSize="@dimen/button_text_size"
                        android:textStyle="bold"
                        android:onClick="@{()->split.onClickOk()}"
                         />
<!--                    android:background="@drawable/btn_background"-->

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>