<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="edit"
            type="com.example.expensetrackerapplication.viewmodel.EditExpenseViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp">

        <LinearLayout
            android:id="@+id/idHeader"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/edit_expense"
                android:textSize="@dimen/app_header_size"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_weight="0.5"
                android:textColor="?attr/colorPrimary"/>
            <ImageView
                android:id="@+id/idBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_cancel"
                android:layout_weight="2.5"
                android:layout_gravity="end"
                android:onClick="@{()->edit.onClickBack()}"
                />
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/idHeader"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="0dp"
                android:clipToPadding="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="20dp"
                    >
                    <TextView
                        android:id="@+id/idDateLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/sub_header_size"
                        android:text="@string/date"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/idFlow1"
                        />
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/idLSelectDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintWidth_percent="0.85"
                        app:layout_constraintEnd_toStartOf="@+id/idCalendarButton"
                        tools:ignore="MissingConstraints">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/idESelectDate"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:inputType="none"
                            android:maxLines="1"
                            android:text="@={edit._selectedDateUi}"
                            android:textSize="@dimen/text_size"

                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageView
                        android:id="@+id/idCalendarButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/calendar_date"
                        app:layout_constraintStart_toEndOf="@+id/idLSelectDate"
                        app:layout_constraintWidth_percent="0.13"/>

                    <androidx.constraintlayout.helper.widget.Flow
                        android:id="@+id/idFlow1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:flow_horizontalStyle="spread_inside"
                        app:flow_horizontalGap="5dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idDateLabel"
                        app:layout_constraintBottom_toTopOf="@+id/idExpenseLabel"
                        app:constraint_referenced_ids="idLSelectDate,idCalendarButton"
                        tools:ignore="MissingConstraints" />

                    <TextView
                        android:id="@+id/idExpenseLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/expense"
                        android:textSize="@dimen/sub_header_size"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@+id/idLNewExpense"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idLSelectDate" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/idLNewExpense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idExpenseLabel"
                        app:layout_constraintBottom_toTopOf="@+id/idCategoryLabel"
                        >

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/idENewExpense"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/currency_rupee"
                            android:drawablePadding="10dp"
                            android:hint="@string/enter_expense"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:nextFocusDown="@id/idDCategories"
                            android:text="@={edit._expenseAmt}"
                            android:textSize="@dimen/text_size" />


                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/idCategoryLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/category"
                        android:textSize="@dimen/sub_header_size"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/idLCategories"
                        app:layout_constraintTop_toBottomOf="@+id/idLNewExpense" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/idLCategories"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select a Category"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idCategoryLabel"
                        app:layout_constraintBottom_toTopOf="@+id/idPaymentTypeLabel"
                        >
                        <AutoCompleteTextView
                            android:id="@+id/idDCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="10dp"
                            android:maxLines="1"
                            android:inputType="none"
                            android:focusable="false"
                            android:clickable="true"
                            android:textSize="@dimen/text_size"
                            android:text="@={edit._selectedCategoryName}"
                            android:drawableStart="@drawable/ic_category"
                            android:drawablePadding="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/idPaymentTypeLabel"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/idCategoryLabel" />


                    </com.google.android.material.textfield.TextInputLayout>


                    <TextView
                        android:id="@+id/idPaymentTypeLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_type"
                        android:textSize="@dimen/sub_header_size"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idLCategories"
                        app:layout_constraintBottom_toTopOf="@+id/idLPaymentType"/>

                    <RadioGroup
                        android:id="@+id/idLPaymentType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="50dp"
                        android:gravity="start"
                        android:checkedButton="@={edit._selectedPaymentType}"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idPaymentTypeLabel"
                        app:layout_constraintBottom_toTopOf="@+id/idRemarksLabel">

                        <RadioButton
                            android:id="@+id/idCashPayment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/cash"
                            android:drawablePadding="5dp"
                            android:textSize="@dimen/text_size"
                            android:layout_marginBottom="2dp"
                            android:onClick="@{() -> edit.fnCashPayment()}"
                            android:text="@string/cash"
                            />
                        <RadioButton
                            android:id="@+id/idCardPayment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/card"
                            android:drawablePadding="5dp"
                            android:textSize="@dimen/text_size"
                            android:layout_marginBottom="2dp"
                            android:onClick="@{() -> edit.fnCardPayment()}"
                            android:text="@string/card" />

                        <!--        </RadioGroup>-->

                        <!--        <RadioGroup-->
                        <!--            android:id="@+id/idLPaymentType2"-->
                        <!--            android:layout_width="match_parent"-->
                        <!--            android:layout_height="wrap_content"-->
                        <!--            android:orientation="horizontal"-->
                        <!--            android:gravity="center"-->
                        <!--            app:layout_constraintEnd_toEndOf="parent"-->
                        <!--            app:layout_constraintStart_toStartOf="parent"-->
                        <!--            app:layout_constraintTop_toBottomOf="@+id/idLPaymentType"-->
                        <!--            app:layout_constraintBottom_toTopOf="@+id/idRemarksLabel">-->


                        <RadioButton
                            android:id="@+id/idUpiPayment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/upi"
                            android:drawablePadding="5dp"
                            android:textSize="@dimen/text_size"
                            android:layout_marginBottom="2dp"
                            android:onClick="@{() -> edit.fnUpiPayment()}"
                            android:text="@string/upi" />
                        <RadioButton
                            android:id="@+id/idSplitPayment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/split"
                            android:drawablePadding="5dp"
                            android:textSize="@dimen/text_size"
                            android:layout_marginBottom="2dp"
                            android:text="@string/split"
                            android:onClick="@{() -> edit.fnSplitPayment()}"
                            />
                        <RadioButton
                            android:id="@+id/idOthersPayment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/other_payment"
                            android:drawablePadding="5dp"
                            android:textSize="@dimen/text_size"
                            android:onClick="@{() -> edit.fnOtherPayment()}"
                            android:layout_marginBottom="2dp"
                            android:text="@string/other" />
                    </RadioGroup>
                    <TextView
                        android:id="@+id/idRemarksLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/remarks"
                        android:textSize="@dimen/sub_header_size"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idLPaymentType"
                        app:layout_constraintBottom_toTopOf="@+id/idLRemarks"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/idLRemarks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idRemarksLabel"
                        app:layout_constraintBottom_toTopOf="@+id/idLayout"
                        >

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/idERemarks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/pencil"
                            android:drawablePadding="10dp"
                            android:hint="@string/add_remarks"
                            android:text="@={edit._remarks}"
                            android:textSize="@dimen/text_size"
                            android:maxLines="3"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <LinearLayout
                        android:id="@+id/idLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/idLRemarks">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_gravity="start">
                            <TextView
                                android:id="@+id/idClear"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackground"
                                android:gravity="center"
                                android:text="@string/clear"
                                android:textColor="?attr/colorPrimary"
                                android:textColorLink="?attr/colorPrimary"
                                android:textSize="@dimen/button_text_size"
                                android:textStyle="bold"
                                android:onClick="@{() -> edit.onClickClear()}"
                                />
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_gravity="start"
                            app:cardCornerRadius="0dp">
                            <TextView
                                android:id="@+id/idEdit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="@string/edit"
                                android:background="@drawable/btn_background"
                                android:textColor="?attr/textColorWhite"
                                android:textColorLink="?attr/colorPrimary"
                                android:textSize="@dimen/button_text_size"
                                android:textStyle="bold"
                                android:onClick="@{() -> edit.onClickEdit()}"
                                />
                        </androidx.cardview.widget.CardView>
<!--                        <com.google.android.material.button.MaterialButton-->
<!--                            android:id="@+id/idAdd"-->
<!--                            android:layout_width="match_parent"-->
<!--                            android:layout_height="match_parent"-->
<!--                            android:layout_weight="1"-->
<!--                            android:textColor="@color/text_color_white"-->
<!--                            android:onClick="@{() -> edit.onClickEdit()}"-->
<!--                            android:text="@string/edit"-->
<!--                            android:textSize="25sp" />-->

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.core.widget.NestedScrollView>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>